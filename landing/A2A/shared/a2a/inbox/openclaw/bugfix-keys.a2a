{"id":"openclaw-bugfix-keys","from":"openclaw","to":"native","ts":1741178400000,"pri":0,"t":"CodeImprove","d":{"file":"src/housaky/heartbeat.rs","diff":"--- a/src/housaky/heartbeat.rs\n+++ b/src/housaky/heartbeat.rs\n@@ -8,7 +8,7 @@\n-use crate::providers::{create_provider, Provider};\n+use crate::providers::{create_provider, create_provider_with_keys_manager, Provider};\n@@ -58,7 +58,7 @@\n-    let self_improvement_provider = create_provider(\n-        config.default_provider.as_deref().unwrap_or(\"openrouter\"),\n-        None,\n-    )?;\n+    let self_improvement_provider = create_provider_with_keys_manager(\n+        config.default_provider.as_deref().unwrap_or(\"openrouter\"),\n+        None,\n+    )?;\n@@ -107,7 +107,7 @@\n-        let provider = create_provider(\n+        let provider = create_provider_with_keys_manager(\n@@ -133,7 +133,7 @@\n-        let provider = create_provider(\n+        let provider = create_provider_with_keys_manager(","language":"rust","confidence":0.98,"explanation":"CRITICAL FIX: heartbeat.rs uses create_provider() which ignores keys.json. Change to create_provider_with_keys_manager() to properly load API keys from the key manager."},"corr_id":null}