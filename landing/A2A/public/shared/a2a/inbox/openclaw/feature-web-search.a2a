{"id":"openclaw-code-websearch","from":"openclaw","to":"native","ts":1741171050000,"pri":1,"t":"CodeImprove","d":{"file":"src/tools/web_search.rs","diff":"--- /dev/null\n+++ b/src/tools/web_search.rs\n@@ -0,0 +1,50 @@\n+use anyhow::Result;\n+use reqwest::Client;\n+use serde::{Deserialize, Serialize};\n+\n+#[derive(Debug, Clone, Serialize, Deserialize)]\n+pub struct SearchResult {\n+    pub title: String,\n+    pub url: String,\n+    pub snippet: String,\n+}\n+\n+pub struct WebSearch {\n+    client: Client,\n+    api_key: Option<String>,\n+}\n+\n+impl WebSearch {\n+    pub fn new(api_key: Option<String>) -> Self {\n+        Self {\n+            client: Client::builder().build().unwrap(),\n+            api_key,\n+        }\n+    }\n+\n+    /// Search using Brave Search API\n+    pub async fn search(&self, query: &str, count: usize) -> Result<Vec<SearchResult>> {\n+        let url = format!(\n+            \"https://api.search.brave.com/res/v1/web/search?q={}&count={}\",\n+            urlencoding::encode(query),\n+            count\n+        );\n+\n+        let mut req = self.client.get(&url);\n+        if let Some(ref key) = self.api_key {\n+            req = req.header(\"X-Subscription-Token\", key);\n+        }\n+\n+        let resp = req.send().await?.json::<serde_json::Value>().await?;\n+\n+        let results = resp[\"web\"][\"results\"]\n+            .as_array()\n+            .map(|arr| {\n+                arr.iter().filter_map(|r| {\n+                    Some(SearchResult {\n+                        title: r[\"title\"].as_str()?.to_string(),\n+                        url: r\"url\"].as_str()?.to_string(),\n+                        snippet: r[\"description\"].as_str().unwrap_or(\"\").to_string(),\n+                    })\n+                }).collect()\n+            })\n+            .unwrap_or_default();\n+\n+        Ok(results)\n+    }\n+}","language":"rust"},"corr_id":null}