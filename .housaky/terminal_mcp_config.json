{
  "name": "housaky-tui",
  "description": "Housaky TUI Control via terminal-mcp",
  "command": "./target/release/housaky",
  "args": ["tui"],
  "cwd": "/home/hautly/housaky",
  "env": {
    "HOUSAKY_LUCID_CMD": "/home/hautly/.lucid/bin/lucid",
    "HOUSAKY_LUCID_BUDGET": "200",
    "TERM": "xterm-256color"
  },
  "nonInteractive": {
    "enabled": true,
    "inputFile": "/home/hautly/housaky/.housaky/shared/inbox/housaky-native/commands.json",
    "outputFile": "/home/hautly/housaky/.housaky/shared/inbox/housaky-native/output.json"
  }
}
